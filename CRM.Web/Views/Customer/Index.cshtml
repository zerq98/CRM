@model CRM.Application.Dto.CustomersListDto
@{
    ViewData["Title"] = "Your customers";
    var statusTypes = ViewData["StatusList"] as List<string>;
}

<div class="container p-0 m-0">
    <div class="row col-2 rounded" style="color:gray">
        Count of customers: @Model.Count
    </div>
    <div class="row">
        <div class="statusCol col-sm-4" style="width:auto 100%" id="1">
            <p style="background-color:white "> statusTypes[0]</p>
            @foreach (var customer in Model.Customers.Where(x => x.Status == statusTypes[0]))
            {
                <p class="draggable" draggable="true">
                    @customer.Name @customer.DealSize
                </p>
            }
        </div>

        <div class="statusCol col-sm-4" id="2">

        </div>

        <div class="statusCol col-sm-4" id="3">

        </div>
    </div>
</div>

@section scripts{
    <script src="~/js/DragDrop.js"></script>
}